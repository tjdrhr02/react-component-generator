{
  "permissions": {
    "deny": {
      "Read": [
        "**/.env*",
        "**/*.key",
        "**/*.pem",
        "**/*.p12",
        "**/*.pfx",
        "**/.aws/**",
        "**/.kube/**",
        "**/.ssh/**",
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/.git/**",
        "**/.vscode/settings.json",
        "**/settings.local.json",
        "**/.DS_Store"
      ]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/check-test.ps1"
          }
        ]
      }
    ]
  }
}
